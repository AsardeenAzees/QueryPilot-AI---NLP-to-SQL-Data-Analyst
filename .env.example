# Server-only credentials. Never prefix these with NEXT_PUBLIC_.
DATABASE_URL=postgresql://querypilot_reader:password@host/database?sslmode=require
DATABASE_ADMIN_URL=postgresql://owner:password@host/database?sslmode=require
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QUERY_RATE_LIMIT_ENABLED=true
QUERY_RATE_LIMIT=20
QUERY_RATE_WINDOW=24h
ENABLE_QUERY_REPAIR=true
# Used only by Playwright's deterministic API mock.
E2E_MOCK_API=false
